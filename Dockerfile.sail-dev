FROM laravelsail/php84-composer:latest
LABEL org.opencontainers.image.authors="Markus Kohn (markus.kohn@sund-xplosion.de)"

# Keep existing project path conventions used by Make targets and scripts.
WORKDIR /web/html

# Match extensions expected by the application/runtime.
RUN docker-php-ext-install pdo_mysql \
	&& pecl install redis \
	&& docker-php-ext-enable redis

# Sail image defaults to /var/www/html in many setups; align both paths.
RUN mkdir -p /web/html && ln -sfn /web/html /var/www/html

# Dev runtime command: simple Laravel server for local use.
CMD ["bash", "-lc", "php artisan serve --host=0.0.0.0 --port=80"]