{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "repositories": [
        {
            "type": "github",
            "url": "https://github.com/Lan2Play/dedicated-server-api",
            "no-api": true,
            "only": ["maniaplanet/dedicated-server-api"]
        },
        {
            "type": "github",
            "url": "https://github.com/Lan2Play/laravel-steam-auth.git",
            "no-api": true,
            "only": ["invisnik/laravel-steam-auth"]
        },
        {
            "type": "github",
            "url": "https://github.com/Lan2Play/html.git",
            "no-api": true,
            "only": ["laravelcollective/html"]
        },
        {
            "type": "github",
            "url": "https://github.com/Lan2Play/ChallongePHP.git",
            "no-api": true,
            "only": ["team-reflex/challonge-php"]
        }
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "8.5.*",
        "laravel/framework": "12.54.1",
        "laravelcollective/html": "dev-6x#27912c0cf2237cc865ed88bb64df7346195d5300",
        "webonyx/graphql-php": "15.31.0",
        "invisnik/laravel-steam-auth": "dev-master#16cb7ea3ac4a7fa08840fd03757f2319318cda59",
        "laravel/socialite": "5.25.0",
        "ignited/laravel-omnipay": "3.7.0",
        "simplesoftwareio/simple-qrcode": "4.2.0",
        "guzzlehttp/guzzle": "7.10.0",
        "php-http/guzzle7-adapter": "1.1.0",
        "team-reflex/challonge-php": "dev-master#1a14361f4e73466c0f8041686f1edad3a479e02a",
        "intervention/image": "3.11.7",
        "intervention/image-laravel": "1.5.7",
        "laravel/tinker": "2.11.1",
        "scssphp/scssphp": "2.1.0",
        "omnipay/paypal": "3.0.2",
        "cviebrock/eloquent-sluggable": "12.0.0",
        "omnipay/stripe": "3.2.0",
        "symfony/routing": "7.4.6",
        "sirprize/postal-code-validator": "1.5.1",
        "artesaos/seotools": "1.3.2",
        "spatie/laravel-cookie-consent": "3.4.0",
        "xpaw/php-source-query-class": "6.0.0",
        "maniaplanet/dedicated-server-api": "dev-master#7de7858f03921997b63aaa9fe2e7f5e98d2bdb76",
        "laravel/ui": "4.6.2",
        "spatie/laravel-database-mail-templates": "3.7.2",
        "laravel/sanctum": "4.3.1",
        "propaganistas/laravel-phone": "6.0.2",
        "symfony/mailgun-mailer": "8.0.0",
        "symfony/http-client": "8.0.7",
        "spatie/backtrace": "1.8.2",
        "haydenpierce/class-finder": "^0.5.3",
        "dompdf/dompdf": "3.1.5",
        "owen-it/laravel-auditing": "^14.0"
    },
    "require-dev": {
        "mockery/mockery": "1.6.12",
        "fakerphp/faker": "1.24.1",
        "phpunit/phpunit": "13.0.5",
        "kitloong/laravel-migrations-generator": "7.3.0",
        "symfony/css-selector": "8.0.6",
        "symfony/dom-crawler": "8.0.6",
        "orangehill/iseed": "3.8.0",
        "squizlabs/php_codesniffer": "4.0.1",
        "filp/whoops": "2.18.4",
        "laravel/telescope": "^5.16",
        "laravel/sail": "^1.53",
        "barryvdh/laravel-debugbar": "4.1.3",
        "barryvdh/laravel-ide-helper": "3.6.1",
        "laravel/boost": "^2.3"
    },
    "autoload": {
        "classmap": [
            "tests/TestCase.php"
        ],
        "psr-4": {
            "App\\": "app/"
        },
        "files": []
    },
    "autoload-dev": {
        "classmap": [
            "tests/TestCase.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Tests\\": "tests/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "php artisan clear-compiled",
            "php artisan optimize"
        ],
        "pre-update-cmd": [
            "php artisan clear-compiled"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ],
        "post-update-cmd": [
            "php artisan optimize"
        ]
    },
    "config": {
        "preferred-install": "dist",
         "allow-plugins": {
            "third-party/required-plugin": true,
            "my-organization/*": true,
            "unnecessary/plugin": false,
            "php-http/discovery": true
        }
    }
}
